# Copy to .env and fill in. .env is gitignored — never commit real keys.

# --- Hosted critics (optional) ---
# Priority per critic: OpenAI/Anthropic > Groq > local Llama fallback.
# If all hosted keys are omitted, every critic falls back to local Llama.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Groq (optional, OpenAI-compatible, fast + free tier) ---
# If set (and no OpenAI/Anthropic key), accuracy uses GROQ_ACCURACY_MODEL and
# logic uses GROQ_LOGIC_MODEL — two DIFFERENT models, preserving diversity.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_ACCURACY_MODEL=llama-3.3-70b-versatile
GROQ_LOGIC_MODEL=qwen/qwen3-32b

# --- Local critic (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3

# --- Model overrides (optional) ---
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Mode ---
# auto       = use hosted models where keys exist, fall back to local otherwise
# local_only = force ALL three critics through Ollama (key-free, lower diversity)
ARBITRATION_MODE=auto
